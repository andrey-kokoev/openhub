{
  "name": "@openhub2/provider-supabase",
  "version": "0.0.1",
  "description": "OpenHub provider for Supabase: Postgres, Redis, Storage",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "clean_install": "rm -rf node_modules dist && pnpm install"
  },
  "dependencies": {
    "@openhub2/types": "workspace:*"
  },
  "devDependencies": {
    "@vitest/ui": "^4.0.18",
    "tsup": "^8.5.1",
    "typescript": "~5.7.3",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public"
  }
}
